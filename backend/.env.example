# ─────────────────────────────────────────────
# InstaPoster — Environment Variables
# Copy to .env and fill in real values.
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/instaposter?schema=public"

# Existing shop schemas (read-only connections)
MAIN_STORE_DB_URL="postgresql://USER:PASSWORD@localhost:5432/main_store?schema=public"
SECONDARY_STORE_DB_URL="postgresql://USER:PASSWORD@localhost:5432/secondary_store?schema=public"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Meta / Instagram Graph API
META_APP_ID="YOUR_META_APP_ID"
META_APP_SECRET="YOUR_META_APP_SECRET"
INSTAGRAM_BUSINESS_ACCOUNT_ID="YOUR_IG_ACCOUNT_ID"
META_ACCESS_TOKEN="YOUR_LONG_LIVED_ACCESS_TOKEN"

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY="YOUR_CONSUMER_KEY"
MPESA_CONSUMER_SECRET="YOUR_CONSUMER_SECRET"
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="YOUR_PASSKEY"
MPESA_ENV="sandbox"   # "sandbox" | "production"
MPESA_CALLBACK_URL="https://yourdomain.com/api/payments/mpesa/callback"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# File storage (for carousel images)
STORAGE_BUCKET="your-s3-bucket-name"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="YOUR_AWS_KEY"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET"

# JWT (optional, for dashboard auth)
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="7d"
